<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Desktop.MainWindow"
        Title="Parking Tizimi"
        Width="1320" Height="860"
        MinWidth="1100" MinHeight="720">
    <Grid ColumnDefinitions="272,*" Background="#F1F5F9">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="22,28,22,24" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="36" Height="36" CornerRadius="10" Background="#6366F1">
                            <TextBlock Text="P" Foreground="White" FontWeight="Bold" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Parking Tizimi" FontSize="17" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock x:Name="SidebarRoleSubtitle" Text="Mehmon" FontSize="11" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Margin="14,0,14,18" Padding="14"
                        Background="#F8FAFC" CornerRadius="14"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="40" Height="40" CornerRadius="20" Background="#EEF2FF">
                                <TextBlock x:Name="UserAvatarText" Text="M" FontWeight="Bold"
                                           Foreground="#6366F1" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" MaxWidth="150">
                                <TextBlock x:Name="SidebarUserName" Text="Mehmon" FontWeight="SemiBold"
                                           Foreground="#0F172A" FontSize="13"/>
                                <TextBlock x:Name="SidebarUserEmail" Text="Kirish kerak" FontSize="11"
                                           Foreground="#94A3B8" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="LogoutButton" Content="Chiqish" IsVisible="False"
                                Click="LogoutButton_Click" HorizontalAlignment="Stretch"
                                Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0"
                                CornerRadius="8" Padding="10,8"/>
                    </StackPanel>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" MaxHeight="560">
                    <StackPanel Margin="10,0,10,12" Spacing="2">
                        <TextBlock x:Name="SectionAsosiyLabel" Text="ASOSIY" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"
                                   Margin="14,0,0,6"/>
                        <Button x:Name="NavDashboardBtn" Classes="nav-active" Content="  Dashboard"
                                Click="NavDashboard_Click"/>
                        <Button x:Name="NavParkingBtn" Classes="nav" Content="  Parking joylar"
                                Click="NavParking_Click"/>
                        <Button x:Name="NavBookingBtn" Classes="nav" Content="  Bron"
                                Click="NavBooking_Click"/>
                        <Button x:Name="NavTariffsBtn" Classes="nav" Content="  Tariflar"
                                Click="NavTariffs_Click"/>

                        <TextBlock x:Name="SectionMoliyaLabel" Text="MOLIYA" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"
                                   Margin="14,12,0,6"/>
                        <Button x:Name="NavPaymentsBtn" Classes="nav" Content="  To'lovlar"
                                Click="NavPayments_Click"/>
                        <Button x:Name="NavReportsBtn" Classes="nav" Content="  Hisobotlar"
                                Click="NavReports_Click"/>

                        <TextBlock x:Name="SectionOperatsiyaLabel" Text="OPERATSIYA" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"
                                   Margin="14,12,0,6"/>
                        <Button x:Name="NavSessionsBtn" Classes="nav" Content="  Sessiyalar"
                                Click="NavSessions_Click"/>
                        <Button x:Name="NavProblemsBtn" Classes="nav" Content="  Muammolar"
                                Click="NavProblems_Click"/>

                        <TextBlock x:Name="SectionBoshqaruvLabel" Text="BOSHQARUV" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"
                                   Margin="14,12,0,6"/>
                        <Button x:Name="NavUsersBtn" Classes="nav" Content="  Foydalanuvchilar" IsVisible="False"
                                Click="NavUsers_Click"/>
                        <Button x:Name="NavOperatorBtn" Classes="nav" Content="  Operator" IsVisible="False"
                                Click="NavOperator_Click"/>
                        <Button x:Name="NavAdminBtn" Classes="nav" Content="  Admin panel" IsVisible="False"
                                Click="NavAdmin_Click"/>

                        <TextBlock x:Name="SectionHisobLabel" Text="HISOB" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"
                                   Margin="14,12,0,6"/>
                        <Button x:Name="NavProfileBtn" Classes="nav" Content="  Profil" IsVisible="False"
                                Click="NavProfile_Click"/>
                        <Button x:Name="NavSetupBtn" Classes="nav" Content="  Sozlash" IsVisible="False"
                                Click="NavSetup_Click"/>
                        <Button x:Name="NavLoginBtn" Classes="nav" Content="  Login"
                                Click="NavLogin_Click"/>
                        <Button x:Name="NavRegisterBtn" Classes="nav" Content="  Register" IsVisible="False"
                                Click="NavRegister_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    Padding="28,16">
                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#64748B" FontSize="13"/>
            </Border>

            <!-- Dashboard page -->
            <ScrollViewer x:Name="DashboardPage" Grid.Row="1" IsVisible="False" Margin="24">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="DashboardTitleText" Text="Dashboard" FontSize="26"
                                   FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock x:Name="DashboardSubtitleText" Text="" Foreground="#64748B" FontSize="13"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                        <Border x:Name="DashCardOccupied" Background="White" CornerRadius="16" Padding="20"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DashCard1Label" Text="Band slotlar" Foreground="#64748B" FontSize="12"/>
                                <TextBlock x:Name="DashOccupiedText" Text="0" FontSize="28" FontWeight="Bold"/>
                                <TextBlock x:Name="DashOccupancyPercentText" Text="0%" Foreground="#6366F1" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="DashCardSecond" Grid.Column="1" Background="White" CornerRadius="16"
                                Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DashCard2Label" Text="Bugungi daromad" Foreground="#64748B" FontSize="12"/>
                                <TextBlock x:Name="DashSecondValueText" Text="0 UZS" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="DashSecondHintText" Text="Jami: 0" Foreground="#64748B" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="DashCardThird" Grid.Column="2" Background="White" CornerRadius="16"
                                Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DashCard3Label" Text="Faol sessiyalar" Foreground="#64748B" FontSize="12"/>
                                <TextBlock x:Name="DashThirdValueText" Text="0" FontSize="28" FontWeight="Bold"/>
                                <TextBlock x:Name="DashThirdHintText" Text="Bron: 0" Foreground="#64748B" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="DashCardFourth" Grid.Column="3" Background="White" CornerRadius="16"
                                Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DashCard4Label" Text="Ochiq muammolar" Foreground="#64748B" FontSize="12"/>
                                <TextBlock x:Name="DashFourthValueText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="#DC2626"/>
                                <TextBlock x:Name="DashFourthHintText" Text="Foydalanuvchilar: 0"
                                           Foreground="#64748B" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border x:Name="DashMapSection" Background="White" CornerRadius="16" Padding="24"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Hududlar xaritasi" FontWeight="SemiBold" FontSize="16"/>
                                <Canvas x:Name="DashboardMapCanvas" Height="280" Background="#F8FAFC"
                                        PointerPressed="DashboardMapCanvas_PointerPressed"/>
                                <TextBlock Text="Yashil — ko'p bosh | Sariq — o'rtacha | Qizil — kam bosh"
                                           FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="DashZoneStatsSection" Grid.Column="1" Background="White" CornerRadius="16"
                                Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Hududlar bandligi" FontWeight="SemiBold" FontSize="16"/>
                                <ItemsControl x:Name="ZoneStatsPanel"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border x:Name="DashRevenueChartSection" Background="White" CornerRadius="16" Padding="24"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="So'nggi 7 kun daromad" FontWeight="SemiBold" FontSize="16"/>
                            <ItemsControl x:Name="RevenueChartPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DashUserActionsSection" Background="#EEF2FF" CornerRadius="16" Padding="20"
                            BorderBrush="#C7D2FE" BorderThickness="1" IsVisible="False">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="DashUserActionsTitle" Text="Tez harakatlar" FontWeight="SemiBold"
                                       Foreground="#4338CA"/>
                            <TextBlock x:Name="DashUserActionsText" TextWrapping="Wrap" Foreground="#64748B"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="DashActionPrimaryBtn" Classes="primary" Click="DashActionPrimary_Click"/>
                                <Button x:Name="DashActionSecondaryBtn" Click="DashActionSecondary_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Parking page -->
            <Grid x:Name="ParkingPage" Grid.Row="1" RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0" Background="White" Padding="28,20,28,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="ParkingTitleText" Text="Parking joylar"
                                       FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock x:Name="ParkingSubtitleText" Text="Hudud tanlang"
                                       Foreground="#64748B" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20"
                                    VerticalAlignment="Center">
                            <StackPanel Spacing="2" HorizontalAlignment="Center">
                                <TextBlock x:Name="OccupiedStatText" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#0F172A"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Band" FontSize="12" Foreground="#64748B"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Border Width="1" Height="36" Background="#E2E8F0"/>
                            <StackPanel Spacing="2" HorizontalAlignment="Center">
                                <TextBlock x:Name="EmptyStatText" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#6366F1"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Bosh" FontSize="12" Foreground="#64748B"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Button Classes="primary" Content="Muammo xabar qilish"
                                    Click="ReportProblem_Click" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled" Margin="28,0,28,0">
                    <StackPanel x:Name="ZonePillsPanel" Orientation="Horizontal" Spacing="8"
                                Margin="0,8,0,12"/>
                </ScrollViewer>

                <ScrollViewer Grid.Row="2" Margin="24,0,24,20">
                    <Border Background="White" CornerRadius="20" Padding="28"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            BoxShadow="0 4 24 0 #15000000">
                        <StackPanel Spacing="16">
                            <TextBlock x:Name="SelectedZoneDetailText" TextWrapping="Wrap"
                                       Foreground="#64748B" FontSize="13"/>
                            <Panel x:Name="FloorGridPanel" MinHeight="420"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <!-- Setup page (birinchi admin) -->
            <ScrollViewer x:Name="SetupPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Grid ColumnDefinitions="*,420" MaxWidth="960">
                    <Border Background="White" CornerRadius="20" Padding="40" Margin="0,0,16,0"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="16" VerticalAlignment="Center">
                            <TextBlock Text="Tizimni sozlash" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Parking tizimi birinchi marta ishga tushirilmoqda. Avval bir admin yaratishingiz kerak — u operatorlarni va tizimni boshqaradi."
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="22"/>
                            <Border Background="#FEF2F2" CornerRadius="12" Padding="14" BorderBrush="#FECACA" BorderThickness="1">
                                <TextBlock Text="Admin yaratilgunga qadar boshqa foydalanuvchilar ro'yxatdan o'ta olmaydi."
                                           Foreground="#DC2626" TextWrapping="Wrap" FontSize="13"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="32"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Birinchi admin" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Ma'mur hisobini yarating" Foreground="#64748B"/>
                            <TextBox x:Name="AdminUsernameBox" PlaceholderText="Admin username"/>
                            <TextBox x:Name="AdminPasswordBox" PlaceholderText="Parol (min 6 belgi)" PasswordChar="*"/>
                            <TextBox x:Name="AdminPhoneBox" PlaceholderText="Telefon (+998XXXXXXXXX)"/>
                            <Button Classes="primary" Content="Admin yaratish va davom etish"
                                    Click="BootstrapAdmin_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Login page -->
            <ScrollViewer x:Name="LoginPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Grid ColumnDefinitions="*,420" MaxWidth="960">
                    <Border Background="White" CornerRadius="20" Padding="40" Margin="0,0,16,0"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="16" VerticalAlignment="Center">
                            <TextBlock Text="Xush kelibsiz!" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Parking Tizimi — Toshkent hududlaridagi parking joylarni boshqarish, bron qilish va monitoring qilish tizimi."
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="22"/>
                            <Border Background="#EEF2FF" CornerRadius="12" Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Demo hisoblar (parol: User123! / Operator123! / Admin123!)"
                                               FontWeight="SemiBold" Foreground="#6366F1" TextWrapping="Wrap"/>
                                    <TextBlock Text="admin · operator · operator2 · demo_user · aziza_k · jamshid_r · nilufar_s ..."
                                               Foreground="#64748B" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="32"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Login" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Hisobingizga kiring" Foreground="#64748B"/>
                            <TextBox x:Name="LoginUsernameBox" PlaceholderText="Username"/>
                            <TextBox x:Name="LoginPasswordBox" PlaceholderText="Parol" PasswordChar="*"/>
                            <Button Classes="primary" Content="Kirish" Click="LoginButton_Click"
                                    HorizontalAlignment="Stretch"/>
                            <Button x:Name="GoToRegisterLink" Content="Hisobingiz yo'qmi? Ro'yxatdan o'ting"
                                    Click="GoToRegister_Click" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6366F1" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Register page -->
            <ScrollViewer x:Name="RegisterPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Grid ColumnDefinitions="*,420" MaxWidth="960">
                    <Border Background="White" CornerRadius="20" Padding="40" Margin="0,0,16,0"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="16" VerticalAlignment="Center">
                            <TextBlock Text="Ro'yxatdan o'tish" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Foydalanuvchi sifatida ro'yxatdan o'ting — avtomobil qo'shing, parking joyini bron qiling va to'lovlarni kuzating."
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="22"/>
                            <Border Background="#F0FDF4" CornerRadius="12" Padding="14" BorderBrush="#BBF7D0" BorderThickness="1">
                                <TextBlock Text="Operator va admin bu yerda ro'yxatdan o'tmaydi. Operatorni admin yaratadi."
                                           Foreground="#16A34A" TextWrapping="Wrap" FontSize="13"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="32"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Yangi hisob" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Foydalanuvchi (User) roli" Foreground="#64748B"/>
                            <TextBox x:Name="RegisterUsernameBox" PlaceholderText="Username"/>
                            <TextBox x:Name="RegisterPasswordBox" PlaceholderText="Parol (min 6 belgi)" PasswordChar="*"/>
                            <TextBox x:Name="RegisterPhoneBox" PlaceholderText="Telefon (+998XXXXXXXXX)"/>
                            <Button Classes="primary" Content="Ro'yxatdan o'tish" Click="RegisterButton_Click"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Allaqachon hisobingiz bormi? Login"
                                    Click="GoToLogin_Click" HorizontalAlignment="Center"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6366F1" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Booking page -->
            <ScrollViewer x:Name="BookingPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Grid ColumnDefinitions="*,400">
                    <Border Background="White" CornerRadius="20" Padding="28" Margin="0,0,16,0"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Yaqin parking qidirish" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="*,*,Auto,Auto" ColumnSpacing="10">
                                <TextBox x:Name="SearchLatBox" PlaceholderText="Kenglik (41.2995)" Grid.Column="0"/>
                                <TextBox x:Name="SearchLngBox" PlaceholderText="Uzunlik (69.2401)" Grid.Column="1"/>
                                <ComboBox x:Name="SearchRadiusBox" Grid.Column="2" MinWidth="100"/>
                                <Button Grid.Column="3" Content="Qidirish" Click="SearchNearby_Click"/>
                            </Grid>
                            <Button Content="Barcha hududlar" Click="RefreshAllZones_Click"
                                    HorizontalAlignment="Left"/>
                            <ListBox x:Name="ZoneListBox" MaxHeight="280"
                                     SelectionChanged="ZoneListBox_SelectionChanged"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="28"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Bron yaratish" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Xaritadan slot tanlang yoki quyida tanlang."
                                       Foreground="#64748B" TextWrapping="Wrap"/>
                            <ComboBox x:Name="ReservationZoneBox"/>
                            <ComboBox x:Name="ReservationSlotBox"/>
                            <ComboBox x:Name="ReservationVehicleBox"/>
                            <Button Classes="primary" Content="Bron qilish (+1 soat)"
                                    Click="CreateReservation_Click" HorizontalAlignment="Stretch"/>
                            <Separator Margin="0,8"/>
                            <TextBlock Text="Avtomobil qo'shish" FontWeight="SemiBold"/>
                            <TextBox x:Name="PlateBox" PlaceholderText="Davlat raqami"/>
                            <TextBox x:Name="ModelBox" PlaceholderText="Model"/>
                            <TextBox x:Name="ColorBox" PlaceholderText="Rang"/>
                            <Button Content="Avtomobil qo'shish" Click="AddVehicle_Click"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Mening ma'lumotlarim" Click="RefreshUserData_Click"
                                    HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Mening bronlarim" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <ListBox x:Name="ReservationsListBox" MaxHeight="120"/>
                            <Button Content="Bronni bekor qilish" Click="CancelReservation_Click"
                                    HorizontalAlignment="Stretch"/>
                            <TextBlock Text="To'lovlar tarixi" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <ListBox x:Name="PaymentsListBox" MaxHeight="120"/>
                            <ListBox x:Name="UserDataListBox" MaxHeight="120"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Admin page -->
            <ScrollViewer x:Name="AdminPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="720"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Admin panel" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Operator yaratish" FontWeight="SemiBold"/>
                        <TextBox x:Name="OperatorUsernameBox" PlaceholderText="Operator username"/>
                        <TextBox x:Name="OperatorPasswordBox" PlaceholderText="Parol" PasswordChar="*"/>
                        <TextBox x:Name="OperatorPhoneBox" PlaceholderText="Telefon"/>
                        <Button Classes="primary" Content="Operator yaratish" Click="CreateOperator_Click"
                                HorizontalAlignment="Left"/>
                        <Button Content="Foydalanuvchilar" Click="RefreshUsers_Click"
                                HorizontalAlignment="Left"/>
                        <ListBox x:Name="UsersListBox" MaxHeight="180"/>
                        <Button Content="Umumiy ko'rinish" Click="RefreshOverview_Click"
                                HorizontalAlignment="Left"/>
                        <TextBlock x:Name="OverviewText" TextWrapping="Wrap" Foreground="#64748B"/>
                        <Separator Margin="0,8"/>
                        <TextBlock Text="Slot holati (Admin)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox x:Name="AdminSlotCodeBox" PlaceholderText="Slot (CHZ-A1)" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="Ta'mirda" Click="SetSlotOutOfService_Click"/>
                            <Button Grid.Column="2" Content="Faol qilish" Click="SetSlotAvailable_Click"/>
                        </Grid>
                        <TextBlock Text="Muammolar" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <Button Content="Muammolarni yangilash" Click="RefreshProblems_Click" HorizontalAlignment="Left"/>
                        <ListBox x:Name="ProblemsListBox" MaxHeight="160"/>
                        <Button Classes="primary" Content="Tanlangan muammoni yopish" Click="ResolveProblem_Click"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Operator page -->
            <ScrollViewer x:Name="OperatorPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="640"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Operator panel" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Check-in" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CheckInUserBox" PlaceholderText="Foydalanuvchi"/>
                        <ComboBox x:Name="CheckInVehicleBox" PlaceholderText="Avtomobil"/>
                        <ComboBox x:Name="CheckInSlotBox" PlaceholderText="Slot"/>
                        <Button Classes="primary" Content="Check-in" Click="CheckIn_Click"
                                HorizontalAlignment="Left"/>
                        <Separator Margin="0,8"/>
                        <TextBlock Text="Check-out" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CheckOutSessionBox" PlaceholderText="Faol sessiya"/>
                        <Button Content="Check-out" Click="CheckOut_Click" HorizontalAlignment="Left"/>
                        <Button Content="Faol sessiyalar" Click="RefreshSessions_Click"
                                HorizontalAlignment="Left"/>
                        <ListBox x:Name="SessionsListBox" MaxHeight="180"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Profile page -->
            <ScrollViewer x:Name="ProfilePage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="520"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Profil" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="ProfileInfoText" TextWrapping="Wrap" Foreground="#64748B"/>
                        <TextBox x:Name="ProfilePhoneBox" PlaceholderText="Yangi telefon"/>
                        <Button Content="Telefonni yangilash" Click="UpdateProfile_Click"
                                HorizontalAlignment="Left"/>
                        <Separator Margin="0,8"/>
                        <TextBox x:Name="CurrentPasswordBox" PlaceholderText="Joriy parol" PasswordChar="*"/>
                        <TextBox x:Name="NewPasswordBox" PlaceholderText="Yangi parol" PasswordChar="*"/>
                        <Button Classes="primary" Content="Parolni o'zgartirish" Click="ChangePassword_Click"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Tariflar page -->
            <ScrollViewer x:Name="TariffsPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="800"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Parking tariflari" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Barcha hududlar bo'yicha soatlik narxlar" Foreground="#64748B"/>
                        <ListBox x:Name="TariffsListBox" MinHeight="360"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- To'lovlar page -->
            <ScrollViewer x:Name="PaymentsPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="800"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="To'lovlar" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="PaymentsSummaryText" Foreground="#64748B"/>
                        <ListBox x:Name="AllPaymentsListBox" MinHeight="360"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Hisobotlar page -->
            <ScrollViewer x:Name="ReportsPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="900"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Hisobotlar" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="ReportsSummaryText" TextWrapping="Wrap" Foreground="#64748B"/>
                        <Button Content="Hisobotni yangilash" Click="RefreshReports_Click" HorizontalAlignment="Left"/>
                        <ListBox x:Name="ReportsDetailListBox" MinHeight="320"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Sessiyalar page -->
            <ScrollViewer x:Name="SessionsPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="900"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Faol sessiyalar" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Hozir parkingda turgan avtomobillar" Foreground="#64748B"/>
                        <Button Content="Yangilash" Click="RefreshAllSessions_Click" HorizontalAlignment="Left"/>
                        <ListBox x:Name="AllSessionsListBox" MinHeight="360"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Muammolar page -->
            <ScrollViewer x:Name="ProblemsPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="900"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Muammolar" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Parking joylari bo'yicha xabarlar" Foreground="#64748B"/>
                        <Button Classes="primary" Content="Yangi muammo xabar qilish"
                                Click="ReportProblem_Click" HorizontalAlignment="Left"/>
                        <Button Content="Ro'yxatni yangilash" Click="RefreshProblemsPage_Click" HorizontalAlignment="Left"/>
                        <ListBox x:Name="AllProblemsListBox" MinHeight="300"/>
                        <Button x:Name="ResolveProblemPageBtn" Classes="primary"
                                Content="Tanlangan muammoni yopish (Admin)"
                                Click="ResolveProblem_Click" HorizontalAlignment="Left" IsVisible="False"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Foydalanuvchilar page -->
            <ScrollViewer x:Name="UsersPage" Grid.Row="1" IsVisible="False" Margin="24">
                <Border Background="White" CornerRadius="20" Padding="32" MaxWidth="800"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Foydalanuvchilar" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Tizimdagi barcha foydalanuvchilar" Foreground="#64748B"/>
                        <Button Content="Yangilash" Click="RefreshUsersPage_Click" HorizontalAlignment="Left"/>
                        <ListBox x:Name="AllUsersListBox" MinHeight="360"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
