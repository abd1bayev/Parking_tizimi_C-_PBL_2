<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1480"
        d:DesignHeight="960"
        x:Class="ParkingTizimi.Desktop.MainWindow"
        Title="Parking Tizimi Desktop"
        MinWidth="1240"
        MinHeight="860"
        Background="#0D1324">
    <Window.Styles>
        <Style Selector="Border.glass-card">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FAFC" Offset="0" />
                    <GradientStop Color="#EEF2FF" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="BorderBrush" Value="#DDE4F3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 18 42 0 #33081820" />
        </Style>

        <Style Selector="Border.dark-card">
            <Setter Property="Background" Value="#111A31" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="BorderBrush" Value="#263557" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="TextBlock.kicker">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6B7A99" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style Selector="TabControl.main-tabs > TabStrip > TabItem">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#E5EAF6" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style Selector="TabControl.main-tabs > TabStrip > TabItem:selected">
            <Setter Property="Background" Value="#101828" />
            <Setter Property="Foreground" Value="#F8FAFC" />
        </Style>
    </Window.Styles>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Canvas.Left="-120" Canvas.Top="-90" Fill="#1D4ED8" Opacity="0.14" />
            <Ellipse Width="340" Height="340" Canvas.Right="-80" Canvas.Top="70" Fill="#14B8A6" Opacity="0.12" />
            <Ellipse Width="300" Height="300" Canvas.Right="240" Canvas.Bottom="-120" Fill="#F97316" Opacity="0.10" />
        </Canvas>

        <Grid Margin="20" RowDefinitions="Auto,*" RowSpacing="18">
            <Border Grid.Row="0" Padding="24" Classes="dark-card">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="18">
                    <Border Width="58" Height="58" CornerRadius="18" Background="#0F766E" VerticalAlignment="Top">
                        <TextBlock Text="P" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="White" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Parking Tizimi" FontSize="34" FontWeight="Bold" Foreground="#F8FAFC" />
                        <TextBlock Text="Professional parking boshqaruvi uchun zamonaviy, ishonchli va aniq ishlovchi ish stoli paneli." Foreground="#94A3B8" TextWrapping="Wrap" MaxWidth="820" />
                        <TextBlock x:Name="FeedbackText" Margin="0,8,0,0" FontWeight="SemiBold" Foreground="#4ADE80" Text="Tizim tayyor." />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="12" HorizontalAlignment="Right">
                        <Border Padding="16,10" CornerRadius="999" Background="#1E293B" HorizontalAlignment="Right">
                            <TextBlock x:Name="RoleBadgeText" Text="Mehmon rejimi" Foreground="#93C5FD" FontWeight="SemiBold" />
                        </Border>
                        <Button x:Name="LogoutButton" Content="Chiqish" Click="LogoutButton_Click" Background="#EF4444" Foreground="White" IsVisible="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="18">
                <Border Grid.Column="0" Padding="22" Classes="dark-card">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">
                            <Border Padding="20" CornerRadius="22" Background="#18233E">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="JORIY HOLAT" Classes="kicker" Foreground="#7DD3FC" />
                                    <TextBlock x:Name="CurrentUserText" Text="Foydalanuvchi: Mehmon" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" />
                                    <TextBlock x:Name="CurrentRoleText" Text="Rol: Mehmon" Foreground="#CBD5E1" />
                                    <TextBlock x:Name="SystemHintText" Text="Avval ma'mur yarating yoki tizimga kiring." Foreground="#94A3B8" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Padding="20" CornerRadius="22" Background="#0F1A30">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="JONLI KO'RSATKICHLAR" Classes="kicker" Foreground="#FCA5A5" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                                        <Border Padding="14" CornerRadius="18" Background="#111F3A">
                                            <StackPanel>
                                                <TextBlock Text="Foydalanuvchilar" Foreground="#8FB0E8" />
                                                <TextBlock x:Name="OverviewUsersText" Text="Foydalanuvchilar: 0" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Padding="14" CornerRadius="18" Background="#111F3A">
                                            <StackPanel>
                                                <TextBlock Text="Joylar" Foreground="#8FB0E8" />
                                                <TextBlock x:Name="OverviewSlotsText" Text="Joylar: 0" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Padding="14" CornerRadius="18" Background="#111F3A">
                                            <StackPanel>
                                                <TextBlock Text="Bronlar" Foreground="#8FB0E8" />
                                                <TextBlock x:Name="OverviewReservationsText" Text="Bronlar: 0" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Padding="14" CornerRadius="18" Background="#111F3A">
                                            <StackPanel>
                                                <TextBlock Text="Faol sessiyalar" Foreground="#8FB0E8" />
                                                <TextBlock x:Name="OverviewSessionsText" Text="Faol sessiyalar: 0" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="20" CornerRadius="22" Background="#18233E">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="ISH JARAYONI" Classes="kicker" Foreground="#FCD34D" />
                                    <TextBlock Text="01. Ma'mur yaratish" Foreground="#E2E8F0" />
                                    <TextBlock Text="02. Operator qo'shish" Foreground="#E2E8F0" />
                                    <TextBlock Text="03. Foydalanuvchini ro'yxatdan o'tkazish" Foreground="#E2E8F0" />
                                    <TextBlock Text="04. Bron, kirish va to'lov nazorati" Foreground="#E2E8F0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" Padding="24" Classes="glass-card">
                    <Grid RowDefinitions="Auto,*" RowSpacing="18">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="14">
                            <StackPanel>
                                <TextBlock Text="Boshqaruv markazi" FontSize="30" FontWeight="Bold" Foreground="#0F172A" />
                                <TextBlock Text="Aniq tuzilma, qulay boshqaruv va professional kuzatuv uchun ishlab chiqilgan asosiy panel." Foreground="#64748B" />
                            </StackPanel>

                            <Border Grid.Column="1" Padding="18,14" CornerRadius="20" Background="#E0F2FE">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Foydalanuvchilar" Foreground="#0C4A6E" />
                                    <TextBlock x:Name="CardUsersText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#082F49" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="18,14" CornerRadius="20" Background="#DCFCE7">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Bo'sh joylar" Foreground="#166534" />
                                    <TextBlock x:Name="CardAvailableSlotsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#14532D" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Padding="18,14" CornerRadius="20" Background="#FCE7F3">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Faol sessiyalar" Foreground="#9D174D" />
                                    <TextBlock x:Name="CardSessionsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#831843" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <TabControl x:Name="GuestTabs" Classes="main-tabs">
                                <TabItem Header="Boshlash">
                                    <ScrollViewer>
                                        <Grid Margin="4" ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                                            <Border Padding="28" CornerRadius="26">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#E0F2FE" Offset="0" />
                                                        <GradientStop Color="#DBEAFE" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel Spacing="16">
                                                    <TextBlock Text="Birinchi ma'mur" FontSize="28" FontWeight="Bold" Foreground="#082F49" />
                                                    <TextBlock Text="Loyihani ishga tushirish uchun birinchi ma'mur akkauntini yarating. Shu bosqichdan keyin operator va foydalanuvchi oqimi ochiladi." Foreground="#334155" TextWrapping="Wrap" />
                                                    <TextBox x:Name="AdminUsernameTextBox" PlaceholderText="Ma'mur foydalanuvchi nomi" />
                                                    <TextBox x:Name="AdminPasswordTextBox" PlaceholderText="Ma'mur paroli" />
                                                    <TextBox x:Name="AdminPhoneTextBox" PlaceholderText="+998901234567" />
                                                    <Button Content="Ma'mur yaratish" Click="CreateAdminButton_Click" Background="#0F766E" Foreground="White" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Padding="26" CornerRadius="26" Background="#0F172A">
                                                <StackPanel Spacing="14">
                                                    <TextBlock Text="Bu nima uchun muhim" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC" />
                                                    <TextBlock Text="Ma'mur yangi operatorlarni yaratadi, joylar holatini kuzatadi va butun parking tizimini markaziy tartibda boshqaradi." Foreground="#CBD5E1" TextWrapping="Wrap" />
                                                    <Border Padding="16" CornerRadius="18" Background="#16233D">
                                                        <TextBlock Text="Tavsiya: kuchli parol tanlang va telefon raqamini +998 formatida kiriting." Foreground="#7DD3FC" TextWrapping="Wrap" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Ro'yxatdan o'tish">
                                    <ScrollViewer>
                                        <Grid Margin="4" ColumnDefinitions="1*,1*" ColumnSpacing="18">
                                            <Border Padding="28" CornerRadius="26" Background="#ECFDF5">
                                                <StackPanel Spacing="16">
                                                    <TextBlock Text="Yangi Foydalanuvchi" FontSize="28" FontWeight="Bold" Foreground="#14532D" />
                                                    <TextBlock Text="Yangi mijozni tez va tartibli tarzda tizimga qo'shish oynasi." Foreground="#3F5C4F" />
                                                    <TextBox x:Name="RegisterUsernameTextBox" PlaceholderText="Foydalanuvchi nomi" />
                                                    <TextBox x:Name="RegisterPasswordTextBox" PlaceholderText="Parol" />
                                                    <TextBox x:Name="RegisterPhoneTextBox" PlaceholderText="+998901234567" />
                                                    <Button Content="Foydalanuvchini ro'yxatdan o'tkazish" Click="RegisterButton_Click" Background="#15803D" Foreground="White" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Padding="28" CornerRadius="26" Background="#FEF3C7">
                                                <StackPanel Spacing="16">
                                                    <TextBlock Text="Tizimga kirish" FontSize="28" FontWeight="Bold" Foreground="#92400E" />
                                                    <TextBlock Text="Ma'mur, operator yoki foydalanuvchi sifatida boshqaruv paneliga kiring." Foreground="#7C5A1A" />
                                                    <TextBox x:Name="LoginUsernameTextBox" PlaceholderText="Foydalanuvchi nomi" />
                                                    <TextBox x:Name="LoginPasswordTextBox" PlaceholderText="Parol" />
                                                    <Button Content="Kirish" Click="LoginButton_Click" Background="#B45309" Foreground="White" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                            <TabControl x:Name="DashboardTabs" Classes="main-tabs" IsVisible="False">
                                <TabItem Header="Umumiy holat">
                                    <ScrollViewer>
                                        <StackPanel Margin="4" Spacing="18">
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                                <Border Padding="22" CornerRadius="24" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Joylar holati" Classes="section-title" />
                                                        <TextBlock Text="Parking hududidagi barcha joylarning joriy bandlik va mavjudlik ko'rinishi." Foreground="#64748B" TextWrapping="Wrap" />
                                                        <ListBox x:Name="OverviewSlotsListBox" Height="320" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Padding="22" CornerRadius="24" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="So'nggi harakatlar" Classes="section-title" />
                                                        <TextBlock Text="So'nggi bronlar va faol sessiyalar yagona oqimda ko'rsatiladi." Foreground="#64748B" TextWrapping="Wrap" />
                                                        <ListBox x:Name="OverviewActivityListBox" Height="320" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem x:Name="AdminTab" Header="Ma'mur">
                                    <ScrollViewer>
                                        <StackPanel Margin="4" Spacing="18">
                                            <Border Padding="24" CornerRadius="24">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#EFF6FF" Offset="0" />
                                                        <GradientStop Color="#E0E7FF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
                                                    <StackPanel Spacing="14">
                                                        <TextBlock Text="Operator yaratish" FontSize="28" FontWeight="Bold" Foreground="#1E3A8A" />
                                                        <TextBlock Text="Xodimlarni tizimga qo'shish, vakolatlarni taqsimlash va kunlik boshqaruvni yo'lga qo'yish oynasi." Foreground="#4B5563" TextWrapping="Wrap" />
                                                        <TextBox x:Name="OperatorUsernameTextBox" PlaceholderText="Operator foydalanuvchi nomi" />
                                                        <TextBox x:Name="OperatorPasswordTextBox" PlaceholderText="Operator paroli" />
                                                        <TextBox x:Name="OperatorPhoneTextBox" PlaceholderText="+998901234567" />
                                                        <Button Content="Operator yaratish" Click="CreateOperatorButton_Click" Background="#1D4ED8" Foreground="White" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Padding="18" CornerRadius="20" Background="#0F172A">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="Ma'mur imkoniyatlari" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" />
                                                            <TextBlock Text="Jamoa tuzilmasi, joylar nazorati va sessiyalar kuzatuvi bitta panelda jamlangan." Foreground="#CBD5E1" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18" RowDefinitions="Auto,Auto" RowSpacing="18">
                                                <Border Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Foydalanuvchilar" Classes="section-title" />
                                                        <ListBox x:Name="AdminUsersListBox" Height="220" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Joylar" Classes="section-title" />
                                                        <ListBox x:Name="AdminSlotsListBox" Height="220" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="1" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Bronlar" Classes="section-title" />
                                                        <ListBox x:Name="AdminReservationsListBox" Height="220" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Faol sessiyalar" Classes="section-title" />
                                                        <ListBox x:Name="AdminSessionsListBox" Height="220" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem x:Name="OperatorTab" Header="Operator">
                                    <ScrollViewer>
                                        <StackPanel Margin="4" Spacing="18">
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                                <Border Padding="24" CornerRadius="24" Background="#EEF6FF" BorderBrush="#D7E8FF" BorderThickness="1">
                                                    <StackPanel Spacing="14">
                                                        <TextBlock Text="Avtomobilni joylashtirish" FontSize="28" FontWeight="Bold" Foreground="#1D4ED8" />
                                                        <TextBlock Text="Foydalanuvchi, avtomobil va joyni tanlang, so'ng sessiyani bitta amal bilan boshlang." Foreground="#64748B" TextWrapping="Wrap" />
                                                        <ComboBox x:Name="OperatorUserComboBox" SelectionChanged="OperatorUserComboBox_SelectionChanged" />
                                                        <ComboBox x:Name="OperatorVehicleComboBox" />
                                                        <ComboBox x:Name="OperatorSlotComboBox" />
                                                        <Button Content="Joylashtirishni tasdiqlash" Click="CheckInButton_Click" Background="#2563EB" Foreground="White" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Padding="24" CornerRadius="24" Background="#FFF5E5" BorderBrush="#F8D8A0" BorderThickness="1">
                                                    <StackPanel Spacing="14">
                                                        <TextBlock Text="Avtomobilni chiqarish" FontSize="28" FontWeight="Bold" Foreground="#C2410C" />
                                                        <TextBlock Text="Faol sessiyani yakunlang va hisob-kitobni aniq hamda tez tarzda tasdiqlang." Foreground="#7C5A1A" TextWrapping="Wrap" />
                                                        <ComboBox x:Name="OperatorSessionComboBox" />
                                                        <Button Content="Chiqishni tasdiqlash" Click="CheckOutButton_Click" Background="#D97706" Foreground="White" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                                <Border Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Joylar jadvali" Classes="section-title" />
                                                        <ListBox x:Name="OperatorSlotsListBox" Height="290" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Faol oqim" Classes="section-title" />
                                                        <ListBox x:Name="OperatorSessionsListBox" Height="290" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem x:Name="UserTab" Header="Foydalanuvchi">
                                    <ScrollViewer>
                                        <StackPanel Margin="4" Spacing="18">
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                                <Border Padding="24" CornerRadius="24" Background="#ECFDF5" BorderBrush="#C7F0D8" BorderThickness="1">
                                                    <StackPanel Spacing="14">
                                                        <TextBlock Text="Avtomobil Qo'shish" FontSize="28" FontWeight="Bold" Foreground="#166534" />
                                                        <TextBlock Text="Avtomobil ma'lumotlarini kiritib, bron va operator amallarini tezlashtiring." Foreground="#4B5563" TextWrapping="Wrap" />
                                                        <TextBox x:Name="VehiclePlateTextBox" PlaceholderText="01A123BC" />
                                                        <TextBox x:Name="VehicleModelTextBox" PlaceholderText="Rusum" />
                                                        <TextBox x:Name="VehicleColorTextBox" PlaceholderText="Rang" />
                                                        <Button Content="Avtomobil qo'shish" Click="AddVehicleButton_Click" Background="#15803D" Foreground="White" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Padding="24" CornerRadius="24" Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1">
                                                    <StackPanel Spacing="14">
                                                        <TextBlock Text="Bron yaratish" FontSize="28" FontWeight="Bold" Foreground="#6D28D9" />
                                                        <TextBlock Text="Joyni qulay va tartibli ko'rsatmalar asosida oldindan band qiling." Foreground="#5B5B7B" TextWrapping="Wrap" />
                                                        <ComboBox x:Name="UserVehicleComboBox" />
                                                        <ComboBox x:Name="UserSlotComboBox" />
                                                        <TextBox x:Name="ReservationStartTextBox" PlaceholderText="2026-06-19 14:00" />
                                                        <TextBox x:Name="ReservationEndTextBox" PlaceholderText="2026-06-19 16:00" />
                                                        <Button Content="Bron yaratish" Click="CreateReservationButton_Click" Background="#7C3AED" Foreground="White" HorizontalAlignment="Left" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Padding="24" CornerRadius="24" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1">
                                                <StackPanel Spacing="14">
                                                    <TextBlock Text="Bronni Bekor Qilish" FontSize="28" FontWeight="Bold" Foreground="#9A3412" />
                                                    <TextBlock Text="Quyida faqat faol bronlar ko'rsatiladi, shuning uchun bekor qilish jarayoni aniq va sodda bo'ladi." Foreground="#7C5A1A" TextWrapping="Wrap" />
                                                    <ComboBox x:Name="UserReservationComboBox" />
                                                    <Button Content="Bronni bekor qilish" Click="CancelReservationButton_Click" Background="#C2410C" Foreground="White" HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>

                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="18">
                                                <Border Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Mening avtomobillarim" Classes="section-title" />
                                                        <ListBox x:Name="UserVehiclesListBox" Height="250" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Mening bronlarim" Classes="section-title" />
                                                        <ListBox x:Name="UserReservationsListBox" Height="250" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Padding="20" CornerRadius="22" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Mening to'lovlarim" Classes="section-title" />
                                                        <ListBox x:Name="UserPaymentsListBox" Height="250" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
