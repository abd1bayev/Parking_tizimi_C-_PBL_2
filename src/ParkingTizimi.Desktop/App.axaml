<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ParkingTizimi.Desktop.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter" />
        </Style>

        <Style Selector="Button">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.92" />
            <Setter Property="RenderTransform" Value="scale(1.015)" />
        </Style>

        <Style Selector="TextBox, ComboBox">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style Selector="ListBox">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>
    </Application.Styles>
</Application>